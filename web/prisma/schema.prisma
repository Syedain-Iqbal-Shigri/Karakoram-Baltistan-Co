generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum DifficultyLevel {
  EASY
  MODERATE
  DIFFICULT
  EXTREME
}

enum PaymentStatus {
  PENDING
  ADVANCE_PAID
  FULLY_PAID
  REFUNDED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  nationality   String?
  role          UserRole  @default(USER)
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

model Trek {
  id              String          @id @default(cuid())
  slug            String          @unique
  title           String
  subtitle        String?
  description     String          @db.Text
  highlights      String[]
  inclusions      String[]
  exclusions      String[]
  itinerary       Json
  pricePerPerson  Decimal         @db.Decimal(10, 2)
  durationDays    Int
  maxGroupSize    Int
  minAge          Int             @default(16)
  difficulty      DifficultyLevel
  maxAltitude     Int
  startLocation   String          @default("Skardu")
  coverImage      String
  gallery         String[]
  metaTitle       String?
  metaDescription String?
  keywords        String[]
  isActive        Boolean         @default(true)
  isFeatured      Boolean         @default(false)
  bookings        Booking[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([slug])
  @@index([isActive, isFeatured])
}

model Booking {
  id                    String        @id @default(cuid())
  bookingReference      String        @unique
  userId                String
  user                  User          @relation(fields: [userId], references: [id])
  trekId                String
  trek                  Trek          @relation(fields: [trekId], references: [id])
  trekTitle             String
  trekSlug              String
  trekDate              DateTime
  numberOfPersons       Int
  pricePerPerson        Decimal       @db.Decimal(10, 2)
  totalAmount           Decimal       @db.Decimal(10, 2)
  advanceAmount         Decimal       @db.Decimal(10, 2)
  remainingAmount       Decimal       @db.Decimal(10, 2)
  bookingStatus         BookingStatus @default(PENDING)
  paymentStatus         PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?
  confirmedAt           DateTime?
  confirmedBy           String?
  adminNotes            String?
  emergencyContact      Json?
  specialRequests       String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([userId])
  @@index([trekId])
  @@index([bookingStatus])
  @@index([trekDate])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
